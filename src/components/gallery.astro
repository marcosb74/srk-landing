---
import { Image } from "astro:assets";
import clase01 from "../../public/clase01.jpeg";
import clase02 from "../../public/clase02.jpeg";
import examen01 from "../../public/examen01.JPG";
import examen02 from "../../public/examen02.JPG";
import examen03 from "../../public/examen03.JPG";
import examen04 from "../../public/examen04.JPG";

const images = [
  {
    src: clase01,
    alt: "Clase en Sin Ryong Kwan",
    span: "md:col-span-2",
  },
  {
    src: clase02,
    alt: "Entrenamiento en el dojang",
    span: "md:col-span-1",
  },
  {
    src: examen01,
    alt: "Examen de cinturones",
    span: "md:col-span-1",
  },
  {
    src: examen02,
    alt: "Examen de formas",
    span: "md:col-span-2",
  },
  {
    src: examen03,
    alt: "Momento del examen",
    span: "md:col-span-2",
  },
  {
    src: examen04,
    alt: "Defensa personal",
    span: "md:col-span-1",
  },
];
---

<section id="galeria" class="py-24">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-5xl md:text-6xl font-bold mb-4 text-balance text-foreground">Nuestra Escuela</h2>
      <p class="text-xl text-muted-foreground max-w-2xl mx-auto text-pretty">
        Momentos que capturan el espíritu de Sin Ryong Kwan
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 auto-rows-[300px]">
      {images.map((image) => (
        <div class={`${image.span} relative overflow-hidden rounded-lg group cursor-pointer`}>
          <Image
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            width={800}
            height={600}
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-background/90 via-background/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
            <p class="text-primary-foreground font-semibold text-lg">{image.alt}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

