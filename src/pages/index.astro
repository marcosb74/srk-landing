---
import Layout from "../layouts/Layout.astro";
import { Hero } from "../components/hero";
import { Programs } from "../components/programs";
import { Instructors } from "../components/instructors";
import { Schedule } from "../components/schedule";
import Gallery from "../components/gallery.astro";
import Novedades from "../components/Novedades.astro";
import { CTA } from "../components/cta";
import Navigation from "../components/navigation";
import InstagramButton from "../components/InstagramButton";
---

<Layout
  title="Taekwondo en Villa Soldati | Sin Ryong Kwan - Academia"
  description="Academia de taekwondo en Villa Soldati. Clases para niños, adolescentes y adultos. Disciplina, respeto y superación."
>
  <main class="min-h-screen">
    <Navigation client:load />
    <Hero />
    <Programs />
    <Instructors />
    <Schedule />
    <Gallery />
    <Novedades />
    <CTA client:load />
    <InstagramButton client:load />
  </main>
</Layout>

